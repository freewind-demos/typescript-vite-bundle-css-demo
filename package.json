{
  "name": "typescript-vite-bundle-css-demo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host --open",
    "build": "vite build",
    "build:lib:css-file": "vite build --config vite.lib.split.config.ts",
    "build:lib:css-in-js": "vite build --config vite.lib.injected.config.ts",
    "build:all": "pnpm run build && pnpm run build:lib:css-file && pnpm run build:lib:css-in-js",
    "inspect:dist": "node scripts/inspect-dist.mjs",
    "inspect:lib": "node scripts/inspect-lib.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "@picocss/pico": "latest"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "jsdom": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
